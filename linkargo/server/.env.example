# ─── Database ──────────────────────────────────────────────────────
# Get this from your PostgreSQL host (Supabase, Railway, Neon, etc.)
DATABASE_URL=postgresql://username:password@host:5432/linkargo

# ─── Auth ───────────────────────────────────────────────────────────
# Change this to any long random string (keep it secret!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-abc123

# ─── Server ─────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend URL (for CORS) ─────────────────────────────────────────
# In production: your Vercel URL, e.g. https://linkargo.vercel.app
FRONTEND_URL=http://localhost:3000
